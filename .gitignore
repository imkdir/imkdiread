# =========================================
# imkdiread App - Root .gitignore
# =========================================

# --- Node Modules (The most important one!) ---
node_modules/
frontend/node_modules/
backend/node_modules/

# --- Build Outputs (Frontend) ---
frontend/dist/
frontend/build/

# --- Environment Variables (Keep secrets safe!) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend/*.log

# --- OS Generated Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Editor / IDE Directories ---
.idea/
.vscode/
*.swp
*.swo

# --- Runtime Database / Media ---
backend/public/*
backend/db/database.sqlite
backups/
